# vim:fileencoding=utf-8:foldmethod=marker
#

macos_option_as_alt yes

# disable confirmation when closing the kitty window
confirm_os_window_close 0 

initial_directory ~

macos_hide_titlebar yes
hide_window_decorations titlebar-only
macos_show_window_title_in none
macos_menubar_title_max_length 0
# macos_titlebar_color #272727

shell /opt/homebrew/bin/fish
editor nvim
shell_integration enabled

remember_window_size  no
initial_window_width  110c
initial_window_height 30c

enable_audio_bell no

#notify_on_cmd_finish invisible 10.0
#notify_on_cmd_finish none
update_check_interval 0

font_family      InconsolataGo Nerd Font
font_size 16.0

enabled_layouts splits


# tab bar styles — colors come from current-theme.conf (catppuccin)
tab_bar_edge top
tab_bar_style slant


allow_closing_windows_with_processes_running yes



allow_remote_control yes
listen_on unix:/tmp/mykitty



map ctrl+j kitten pass_keys.py bottom ctrl+j
map ctrl+k kitten pass_keys.py top    ctrl+k
map ctrl+h kitten pass_keys.py left   ctrl+h
map ctrl+l kitten pass_keys.py right  ctrl+l


#map ctrl+alt+h launch --location=hsplit
#map ctrl+alt+v launch --location=vsplit

map cmd+alt+w close_window
map cmd+w no_op
map cmd+q close_os_window

# Navigate splits
map cmd+h neighboring_window left
map cmd+j neighboring_window down
map cmd+k neighboring_window up
map cmd+l neighboring_window right

# Create splits in a specific direction (left/up need a move_window since
# kitty only places new splits right/below)
map cmd+shift+l launch --cwd=current --location=vsplit
map cmd+shift+h combine : launch --cwd=current --location=vsplit : move_window left
map cmd+shift+j launch --cwd=current --location=hsplit
map cmd+shift+k combine : launch --cwd=current --location=hsplit : move_window up

# Tabs
map cmd+t new_tab_with_cwd
map cmd+, previous_tab
map cmd+. next_tab

map shift+enter send_text all \x1b\r

map shift+up move_window up
map shift+down move_window down  
map shift+left move_window left
map shift+right move_window right

map ctrl+shift+up resize_window taller 3
map ctrl+shift+down resize_window shorter 3
map ctrl+shift+right resize_window wider 3
map ctrl+shift+left resize_window narrower 3


# Theme — updated by switch-theme.sh when macOS appearance changes
# To manually set: copy ~/.config/kitty/themes/catppuccin-{frappe,latte}.conf to current-theme.conf
include current-theme.conf
