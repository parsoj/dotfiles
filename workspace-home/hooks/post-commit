#!/bin/bash
# workspace-home post-commit: back up this workspace branch to origin.
# Best-effort and fully backgrounded — offline/no-remote never blocks or
# delays a commit. Remote: github.com/parsoj/workspace-home (private).
git remote get-url origin >/dev/null 2>&1 || exit 0
(git push --quiet origin HEAD >/dev/null 2>&1 &)
exit 0
