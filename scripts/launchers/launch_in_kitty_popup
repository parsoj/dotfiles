#!/usr/bin/env bash

# Script to launch a given command in a kitty popup window.
# Uses kitty @ remote control to open in the already-running kitty process (fast).
# Falls back to a cold launch if kitty isn't running.

keep_window_open=false
declare -a command_to_run_in_kitty=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        -k|--keep-open)
            keep_window_open=true
            shift
            ;;
        --)
            shift
            command_to_run_in_kitty=("$@")
            break
            ;;
        -*)
            command_to_run_in_kitty=("$@")
            break
            ;;
        *)
            command_to_run_in_kitty=("$@")
            break
            ;;
    esac
done

if [ "${#command_to_run_in_kitty[@]}" -eq 0 ]; then
  echo "Usage: $(basename "$0") [-k|--keep-open] [--] <command_to_run> [args...]" >&2
  exit 1
fi

KITTY_BIN="/Applications/kitty.app/Contents/MacOS/kitty"
full_command_string="${command_to_run_in_kitty[*]}"

launch_args=(
    --type=os-window
    --title "kitty-popup"
)
if $keep_window_open; then
    launch_args+=(--hold)
fi

# Use remote control to open in the already-running kitty (fast)
if "$KITTY_BIN" @ --to unix:/tmp/mykitty launch "${launch_args[@]}" -- /opt/homebrew/bin/fish -c "$full_command_string" 2>/dev/null; then
    exit 0
fi

# Fallback: cold launch
open /Applications/kitty.app -n --args --title "kitty-popup" -- /opt/homebrew/bin/fish -c "$full_command_string"
