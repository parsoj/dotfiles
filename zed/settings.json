// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_servers": {
    "groundcover": {
      "source": "custom",
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@0.1.8",
        "https://mcp.groundcover.com/api/mcp",
        "54278",
        "--header",
        "X-Timezone:America/New_York",
        "--header",
        "X-Tenant-UUID:78562531-45b1-49d4-a8fb-422654a6aa74",
        "--header",
        "X-Backend-Id:groundcover"
      ]
    },
    "postgres-context-server": {
      "source": "extension",
      "enabled": true,
      "settings": {
        "database_url": " postgres://steampipe:pwd@127.0.0.1:9193/steampipe"
      }
    }
  },
  "agent": {
    "dock": "right",
    "always_allow_tool_actions": true,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-1-latest"
    }
  },
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "Catppuccin",
    "dark": "One Dark"
  },
  "minimap": {
    "show": "never"
  },
  "telemetry": {
    "metrics": false
  },
  "edit_predictions": {
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },

  "git_panel": {
    "dock": "right"
  },

  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },

  "gutter": {
    "line_numbers": false,
    "breakpoints": false,
    "runnables": false,
    "folds": false
  },

  "title_bar": {
    "show_sign_in": true,
    "show_user_picture": true
  },
  "outline_panel": {
    "button": false
  },
  "preferred_line_length": 100,

  "terminal": {
    "dock": "right",
    "copy_on_select": false,
    "font_family": "Iosevka Term"
  },

  "icon_theme": {
    "dark": "Zed (Default)",
    "light": "Catppuccin Latte",
    // Mode to use (dark, light) or "system" to follow the OS's light/dark mode (default)
    "mode": "system"
  },

  "ui_font_size": 15,
  "buffer_font_size": 14,
  "buffer_font_family": "Iosevka Term",
  "ui_font_family": "Iosevka Term"
}
