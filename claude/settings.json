{
  "permissions": {
    "deny": [
      "Bash(tofu apply*)",
      "Bash(terraform apply*)",
      "Bash(helmfile apply*)",
      "Bash(tofu destroy*)",
      "Bash(terraform destroy*)",
      "Bash(kubectl get secret*-o*)",
      "Bash(kubectl get secrets*-o*)",
      "Bash(kubectl describe secret*)",
      "Bash(kubectl describe secrets*)",
      "Bash(kubectl exec*printenv*)",
      "Bash(kubectl exec*env*)",
      "Bash(kubectl exec*cat*)",
      "Bash(kubectl exec*-- env*)",
      "Bash(*base64 -d*)",
      "Bash(*base64 --decode*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-tab-state.sh idle"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-tab-state.sh working"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-tab-state.sh working"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-tab-state.sh working"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/on-stop.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-input.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-tab-state.sh waiting"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "tennr-tools": {
      "source": {
        "source": "github",
        "repo": "Tennr-Inc/Tennr"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    }
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "theme": "auto",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false,
  "allowedTools": [
    "Bash(grep:*)",
    "Bash(rg:*)",
    "Bash(ls:*)",
    "Bash(find:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(which:*)",
    "Bash(file:*)",
    "Bash(du:*)",
    "Bash(df:*)",
    "Bash(pwd:*)",
    "Bash(echo:*)",
    "Bash(tree:*)"
  ]
}
